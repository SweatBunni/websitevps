# ── CodexMC VPS environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Required: your OpenRouter API key (https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override the default AI model
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct:free

# Optional: shown as HTTP referer in OpenRouter requests
OPENROUTER_HTTP_REFERER=https://your-domain.com

# Optional: shown as app title in OpenRouter requests
OPENROUTER_APP_TITLE=CodexMC

# Optional: port to listen on (default 3000)
PORT=3000

# Optional: address to bind (default 0.0.0.0)
HOST=0.0.0.0

# Optional: where to store build job data (default .data/build-jobs inside the project)
BUILD_STORE_DIR=.data/build-jobs
