# CodexMC Environment Configuration
# Copy this to .env and fill in your values

# Anthropic API Key (uses claude-sonnet-4-20250514 - best free-tier model)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Mod Generation Settings
WORKSPACE_DIR=/tmp/codexmc-workspaces
MAX_CONCURRENT_BUILDS=3
BUILD_TIMEOUT_MS=300000

# JDK Installation Paths (auto-set by setup script)
JDK_21_PATH=/opt/jdk/21
JDK_17_PATH=/opt/jdk/17
JDK_8_PATH=/opt/jdk/8

# Rate Limiting
MAX_REQUESTS_PER_HOUR=20
