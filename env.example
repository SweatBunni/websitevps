# Copy to `.env.local` for local runs. Do not commit real keys.

# --- Mistral (required) ---
# Get key: https://console.mistral.ai/
MISTRAL_API_KEY=
# OpenAI-compatible endpoint; default shown for clarity
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# Default coding model
# MISTRAL_MODEL=codestral-latest
# Optional comma-separated fallbacks
# MISTRAL_MODEL_FALLBACKS=codestral-latest,mistral-small-latest

# Retries per model (0–12, default 6). Lower for faster failover on noisy free APIs.
# AI_MAX_RETRIES=6

# Optional explicit JDK homes on your VPS
# JDK_21_HOME=/opt/codexmc/jdks/21
# JDK_25_HOME=/opt/codexmc/jdks/25
# JDK_17_HOME=/opt/codexmc/jdks/17
