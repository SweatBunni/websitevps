# Copy to `.env.local` for local runs. Do not commit real keys.

# --- LLM backend: OpenRouter (cloud) or Ollama (local / VPS) ---
# openrouter | ollama (alias: local)
AI_PROVIDER=openrouter

# --- OpenRouter (when AI_PROVIDER=openrouter) ---
# https://openrouter.ai/keys — must start with sk-or-v1-
OPENROUTER_API_KEY=
# OPENAI_API_KEY=   # optional; used if it looks like sk-or-... and OPENROUTER_API_KEY is unset
AI_MODEL=qwen/qwen2.5-coder-32b-instruct:free
# AI_MODEL_FALLBACKS=model-a,model-b
OPENROUTER_SITE_URL=http://localhost:3000

# --- Ollama (when AI_PROVIDER=ollama) ---
# OpenAI-compatible base URL (must end with /v1). Same host as Next = http://127.0.0.1:11434/v1
# Docker → host: http://host.docker.internal:11434/v1
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# Main model (optional). Unset = qwen3-coder-next (best Qwen3 Coder on Ollama; ~52GB — use qwen3-coder:30b if needed)
# OLLAMA_MODEL=qwen3-coder-next
# Tried after OLLAMA_MODEL, before built-in qwen3/qwen2.5 coder chain
# OLLAMA_MODEL_FALLBACKS=qwen3-coder:30b

# Retries per model (0–12, default 6). Lower for faster failover on noisy free APIs.
# AI_MAX_RETRIES=6

# Optional explicit JDK homes on your VPS
# JDK_21_HOME=/opt/codexmc/jdks/21
# JDK_25_HOME=/opt/codexmc/jdks/25
# JDK_17_HOME=/opt/codexmc/jdks/17
