# Copy to `.env.local` for local runs. Do not commit real keys.

# https://openrouter.ai/keys — value must start with sk-or-v1- (no quotes, no "Bearer " prefix)
OPENROUTER_API_KEY=
# Optional: if this is an OpenRouter key (sk-or-...), it is used when OPENROUTER_API_KEY is unset
# OPENAI_API_KEY=

# Primary model. “:free” models share upstream quotas and often return HTTP 429 — CodexMC tries fallbacks next.
AI_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Optional extra models (comma-separated), tried after AI_MODEL before built-in defaults
# AI_MODEL_FALLBACKS=qwen/qwen3-coder:free,deepseek/deepseek-chat:free
# Retries per model for transient errors (0–12, default 6)
# AI_MAX_RETRIES=6

OPENROUTER_SITE_URL=http://localhost:3000

# Optional explicit JDK homes on your VPS
# JDK_21_HOME=/opt/codexmc/jdks/21
# JDK_25_HOME=/opt/codexmc/jdks/25
# JDK_17_HOME=/opt/codexmc/jdks/17
